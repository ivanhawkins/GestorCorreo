# Default Account Configuration
DEFAULT_EMAIL_ADDRESS=me@example.com
DEFAULT_USERNAME=me@example.com
DEFAULT_PASSWORD=secure_password
DEFAULT_IMAP_HOST=imap.example.com
DEFAULT_IMAP_PORT=993
DEFAULT_SMTP_HOST=smtp.example.com
DEFAULT_SMTP_PORT=587

# AI Configuration (fallback if not set in DB via Settings)
# These are optional if you configure the AI via the web UI Settings panel
AI_API_URL=https://your-ai-server/chat/models
AI_API_KEY=your_api_key_here
AI_PRIMARY_MODEL=gpt-oss:120b-cloud
AI_SECONDARY_MODEL=qwen3-coder:480b-cloud

# CORS extra origins (comma-separated, optional)
# The production domain https://correos.hawkins.es is always included
# ALLOWED_ORIGINS=https://other-domain.com
